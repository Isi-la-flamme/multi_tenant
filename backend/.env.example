# ============================================
# Configuration de l'application
# ============================================

# Environnement
NODE_ENV=development
PORT=3000

# Base de données PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=secret
DB_NAME=multitenant_db

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=votre-secret-jwt-tres-long-et-aleatoire
JWT_EXPIRATION=24h

# Configuration multitenant
TENANT_HEADER=X-Tenant-Subdomain
DEFAULT_TENANT=demo